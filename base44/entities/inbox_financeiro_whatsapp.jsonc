{
  "name": "inbox_financeiro_whatsapp",
  "type": "object",
  "properties": {
    "telefone_remetente": {
      "type": "string"
    },
    "funcionario_id": {
      "type": "string"
    },
    "loja_id": {
      "type": "string"
    },
    "mensagem_original": {
      "type": "string"
    },
    "origem": {
      "type": "string",
      "enum": [
        "whatsapp"
      ],
      "default": "whatsapp"
    },
    "tipo_entrada": {
      "type": "string",
      "enum": [
