      "type": "boolean",
      "default": false
    },
    "eh_conta_pagar": {
      "type": "boolean",
      "default": false
    },
    "eh_despesa_paga": {
      "type": "boolean",
      "default": false
    },
    "eh_comprovante_pagamento": {
      "type": "boolean",
      "default": false
    },
    "eh_orcamento": {
      "type": "boolean",
      "default": false
    },
    "json_extraido": {
      "type": "string"
    },
    "observacao_ia": {
      "type": "string"
    },
    "erro": {
      "type": "string"
    },
    "criado_em": {
      "type": "string",
      "format": "date-time"
    },
    "processado_em": {
      "type": "string",
      "format": "date-time"
    },
    "confirmado_em": {
