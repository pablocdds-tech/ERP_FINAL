        "recibo",
        "boleto",
        "comprovante_pix",
        "comprovante_cartao",
        "comprovante_transferencia",
        "despesa_manual_texto",
        "despesa_por_audio",
        "compra_estoque",
        "compra_embalagem",
        "manutencao",
        "material_limpeza",
        "pagamento_funcionario",
        "motoboy_extra",
        "sangria_caixa",
        "reembolso",
        "orcamento",
        "outros"
      ]
    },
    "tipo_documento": {
      "type": "string"
    },
    "arquivo_url": {
      "type": "string"
    },
    "tipo_arquivo": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "recebido",
        "processando",
        "classificado",
        "precisa_revisao",
        "aguardando_confirmacao",
        "lancado",
        "duplicado",
        "cancelado",
        "erro"
      ],
      "default": "recebido"
    },
    "fornecedor_nome": {
      "type": "string"
    },
    "fornecedor_cnpj": {
      "type": "string"
    },
    "numero_documento": {
      "type": "string"
    },
    "chave_acesso": {
      "type": "string"
    },
    "data_documento": {
      "type": "string",
      "format": "date"
    },
    "data_vencimento": {
      "type": "string",
      "format": "date"
    },
    "valor_total": {
      "type": "number"
    },
    "forma_pagamento": {
      "type": "string"
    },
    "conta_origem": {
      "type": "string"
    },
    "categoria_financeira_sugerida": {
      "type": "string"
    },
    "categoria_financeira_id_confirmada": {
      "type": "string"
    },
    "centro_custo_sugerido": {
      "type": "string"
    },
