{
  "name": "Chamado",
  "type": "object",
  "properties": {
    "titulo": {
      "type": "string"
    },
    "descricao": {
      "type": "string"
    },
    "loja_id": {
      "type": "string"
    },
    "colaborador_id": {
      "type": "string"
    },
    "categoria": {
      "type": "string",
      "enum": [
        "manutencao",
        "ti",
        "limpeza",
        "operacional",
        "rh",
        "outro"
      ],
      "default": "outro"
    },
    "prioridade": {
      "type": "string",
      "enum": [
        "baixa",
        "media",
        "alta",
        "critica"
      ],
      "default": "media"
    },
    "equipamento_id": {
      "type": "string",
      "description": "Equipamento relacionado, se aplic\u00e1vel"
    },
    "fotos": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "aberto",
        "em_atendimento",
        "resolvido",
        "cancelado"
      ],
      "default": "aberto"
    },
    "respondido_por": {
      "type": "string"
    },
    "resposta": {
      "type": "string"
    },
    "resolvido_em": {
      "type": "string",
      "format": "date-time"
    },
    "tarefa_id": {
      "type": "string",
      "description": "Tarefa criada a partir deste chamado"
    },
    "ordem_servico_id": {
      "type": "string",
      "description": "OS criada a partir deste chamado"
    },
    "ocorrencia_id": {
      "type": "string"
    }
  },
  "required": [
    "titulo"
  ]
}